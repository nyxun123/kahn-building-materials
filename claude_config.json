{
  "mcpServers": {
    "zen": {
      "command": "sh",
      "args": [
        "-c",
        "for p in $(which uvx 2>/dev/null) $HOME/.local/bin/uvx /opt/homebrew/bin/uvx /usr/local/bin/uvx uvx; do [ -x \"$p\" ] && exec \"$p\" --from git+https://github.com/BeehiveInnovations/zen-mcp-server.git zen-mcp-server; done; echo 'uvx not found' >&2; exit 1"
      ],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:~/.local/bin",
        "GEMINI_API_KEY": "your_gemini_api_key_here",
        "OPENAI_API_KEY": "your_openai_api_key_here"
      }
    },
    "chrome-devtools": {
      "command": "/usr/local/bin/npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--logFile=/Users/nll/Documents/可以用的网站/tmp/chrome-mcp.log",
        "--userDataDir=/Users/nll/Documents/可以用的网站/tmp-chrome-profile"
      ],
      "env": {
        "npm_config_cache": "/Users/nll/Documents/可以用的网站/tmp/.npm-cache",
        "npm_config_offline": "true",
        "DEBUG": "mcp:*",
        "PATH": "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:~/.local/bin"
      }
    },
    "zai-mcp-server": {
      "command": "sh",
      "args": [
        "-c",
        "set -a; if [ -f .env ]; then . ./.env; fi; set +a; exec npx -y @z_ai/mcp-server"
      ],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:~/.local/bin",
        "Z_AI_API_KEY": "$ZHIPU_API_KEY",
        "Z_AI_MODE": "ZHIPU"
      }
    }
  }
}
